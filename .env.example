# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Browserless.io (server-only — never expose to client)
BROWSERLESS_TOKEN=your_browserless_token
# Regional base host only (no trailing path required).
# Code appends /chromium/playwright for Playwright connect.
# Do NOT use legacy wss://chrome.browserless.io (404/408).
# Other regions: production-lon, production-ams, etc. (see Browserless dashboard)
BROWSERLESS_WS_ENDPOINT=wss://production-sfo.browserless.io
# Optional / unused on WS connect: do not set timeout query on Playwright URL
# (causes 408 on connect with current Browserless BaaS). Kept for compatibility.
# BROWSERLESS_TIMEOUT=60


# Comma-separated emails that should be admin when profile is bootstrapped
ADMIN_EMAILS=admin@example.com

# Optional
NEXT_PUBLIC_SITE_URL=http://localhost:3000
