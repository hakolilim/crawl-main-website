# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Browserless.io (server-only — never expose to client)
BROWSERLESS_TOKEN=your_browserless_token
# Base host only (code appends /playwright for Playwright connect)
BROWSERLESS_WS_ENDPOINT=wss://chrome.browserless.io
# Session timeout in SECONDS (1–60000). Do NOT use milliseconds (e.g. 120000 is invalid).
BROWSERLESS_TIMEOUT=60


# Comma-separated emails that should be admin when profile is bootstrapped
ADMIN_EMAILS=admin@example.com

# Optional
NEXT_PUBLIC_SITE_URL=http://localhost:3000
